# --- Required ---

# Comma-separated Discord bot tokens (1..MAX_BOT_INSTANCES)
DISCORD_TOKENS=token1,token2

# Lavalink connection
#  - docker-compose: use the service name → `lavalink`
#  - Railway: use the FQDN → `<service-name>.railway.internal` (e.g. `lavalink.railway.internal`)
LAVALINK_HOST=lavalink
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# PostgreSQL connection
#  - docker-compose: postgres://postgres:postgres@postgres:5432/music_bot
#  - Railway: inject via reference variable → ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgres://postgres:postgres@postgres:5432/music_bot

# --- Optional ---

# Multi-bot / capacity
MAX_BOT_INSTANCES=4
MAX_PLAYERS_PER_BOT=50
MAX_QUEUE_SIZE=500

# Memory control
# MEMORY_LIMIT_MB=460
MEMORY_SOFT_LIMIT_PERCENT=90

# DB pool
DB_POOL_SIZE=4

# Dev guild for instant slash command sync
# DEV_GUILD_ID=123456789012345678

# Environment / logging
APP_ENV=production
LOG_LEVEL=INFO

# --- Lavalink-side (lavalink service only) ---
LAVALINK_SERVER_PASSWORD=youshallnotpass
LAVALINK_MAX_HEAP_MB=192

# Optional source credentials (LavaSrc)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# APPLE_MUSIC_TOKEN=
